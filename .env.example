# 数字生命运行配置示例
# 说明：仓库只保留示例，不提交真实 key/token。真实值请放本地 `.env`，或通过 `DIGITAL_LIFE_ENV_FILE` 指向其他文件。

# 数字生命运行档位。用于区分本地试验、常驻运行、受限运行等。
DIGITAL_LIFE_RUNTIME_PROFILE=resident

# 模型提供方标识。当前默认是 local，后续可切换为具体模型网关或本地推理后端。
DIGITAL_LIFE_MODEL_PROVIDER=local

# 模型名称。用于运行时报告和后续模型接线定位。
DIGITAL_LIFE_MODEL_NAME=digital-life-core

# 模型基址。只有在实际接外部模型时才需要。
DIGITAL_LIFE_MODEL_BASE_URL=

# 模型密钥。不要填写真实密钥到示例文件。
DIGITAL_LIFE_MODEL_API_KEY=

# 生成温度。为空表示由内核默认值处理。
DIGITAL_LIFE_MODEL_TEMPERATURE=

# 最大输出 token 数。为空表示由内核默认值处理。
DIGITAL_LIFE_MODEL_MAX_OUTPUT_TOKENS=

# 请求超时秒数。为空表示由内核默认值处理。
DIGITAL_LIFE_MODEL_TIMEOUT_SECONDS=

# 生命体对外交互的默认语言。
DIGITAL_LIFE_RESPONSE_LANGUAGE=zh-CN

# 对话风格标识。用于关系性表达层记录。
DIGITAL_LIFE_DIALOGUE_STYLE=relationship

# 是否默认严格模式。true/false。
DIGITAL_LIFE_STRICT_DEFAULT=false

# 如果本地不想把真实 `.env` 放在仓库根目录，可在 shell 里把这里指向其他文件路径。
# DIGITAL_LIFE_ENV_FILE=/absolute/path/to/your/local.env
